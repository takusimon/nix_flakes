	  "keyColor":"#7287fd"
    },
    {
      "type": "disk",
      "keyIcon": "в”њв”Ђп‚ ",
	  "keyColor":"#7287fd",
      "showRegular": true,
      "showExternal": true,
      "showHidden": false,
      "showSubvolumes": false,
      "showReadOnly": true,
      "showUnknown": false,
      "folders": "",
